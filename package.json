{
  "name": "terra-classic-docs",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run docs:index && vite --host 127.0.0.1",
    "docs:index": "node scripts/build-docs-index.mjs",
    "docs:validate": "node scripts/validate-docs.mjs",
    "docs:routes": "node scripts/write-static-routes.mjs",
    "docs:check": "npm run docs:index && npm run docs:validate",
    "seo:validate": "node scripts/validate-static-seo.mjs",
    "typecheck": "tsc -b --pretty",
    "build": "npm run docs:index && npm run docs:validate && tsc -b && vite build && npm run docs:routes && npm run seo:validate",
    "preview": "vite preview --host 127.0.0.1",
    "check": "npm run build"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
